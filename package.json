{
  "name": "resellengine",
  "version": "0.1.0",
  "description": "Automated reselling platform for Vinted, Kleinanzeigen and cross-marketplaces.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "build": "tsc",
    "test:search": "tsx scripts/test-search.ts",
    "db:init": "tsx scripts/db-init.ts",
    "scraper:install": "playwright install chromium",
    "web:build": "cd web && npm install && npm run build",
    "web:dev": "cd web && npm run dev"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@supabase/supabase-js": "^2.108.2",
    "axios": "^1.7.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "playwright": "^1.45.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sql.js": "^1.10.3",
    "user-agents": "^1.1.350"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
