# Server config
PORT=3000
NODE_ENV=development

# Comma-separated allowed CORS origins (supports glob-style * for subdomains)
# Example: https://app.deinedomain.de,https://*.deinedomain.de
ALLOWED_ORIGINS=

# Supabase (PostgreSQL via service_role key for backend/scraper)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# AI API keys
GEMINI_API_KEY=your-gemini-key
REMOVE_BG_API_KEY=your-removebg-key
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key

# Notifications
DISCORD_WEBHOOK_URL=
DISCORD_FILTER_WEBHOOK_URL=

# Sourcing scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MS=180000

# Anti-bot delays between jobs (ms)
MIN_DELAY_MS=2000
MAX_DELAY_MS=5000

# Vinted session cookie (optional, helps avoid blocks)
VINTED_SESSION_COOKIE=

# Decodo web scraping API for eBay sold-price lookup
DECODO_API_USERNAME=your-decodo-username
DECODO_API_PASSWORD=your-decodo-password

# Fee / shipping defaults
SHIPPING_ESTIMATE=5.0
VINTED_SELLER_FEE_PERCENT=0
VINTED_BUYER_PROTECTION_PERCENT=0.05
